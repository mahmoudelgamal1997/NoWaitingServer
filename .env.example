# Copy to .env and fill in (never commit .env).
# For local development:
# MONGO_URI=mongodb://127.0.0.1:27017/your_db

# To import legacy Excel into PRODUCTION data, point this at the same DB as Heroku:
#   heroku config:get MONGO_URI -a <app>
#   heroku config:get MONGODB_URI -a <app>   # if you use Mongo add-on
# Then run: npm run dev
# Use admin-portal with VITE_API_PROXY_TARGET=http://127.0.0.1:7000

MONGO_URI=
# MONGODB_URI=
